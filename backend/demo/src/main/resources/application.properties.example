# Spring datasource (set in your real application.properties)
# spring.datasource.url=jdbc:postgresql://localhost:5432/secondbrain
# spring.datasource.username=...
# spring.datasource.password=...

# AIML FastAPI endpoint for embeddings
aiml.base-url=http://localhost:8001

# Pinecone storage for chunk embeddings and similarity query
pinecone.api-key=YOUR_PINECONE_API_KEY
pinecone.index-host=https://YOUR_INDEX_HOST.svc.YOUR_ENV.pinecone.io
pinecone.namespace=secondbrain
vector.store.dimensions=1536

# cosine similarity threshold + max matches per chunk for chunk-to-chunk semantic edges
semantic.threshold=0.7
semantic.top-k=8

# Google OAuth2 (required for Google Docs onboarding)
# spring.security.oauth2.client.registration.google.client-id=YOUR_GOOGLE_CLIENT_ID
# spring.security.oauth2.client.registration.google.client-secret=YOUR_GOOGLE_CLIENT_SECRET
# spring.security.oauth2.client.registration.google.scope=openid,profile,email,https://www.googleapis.com/auth/documents.readonly,https://www.googleapis.com/auth/drive.metadata.readonly
# spring.security.oauth2.client.registration.google.redirect-uri={baseUrl}/login/oauth2/code/{registrationId}
# app.frontend-google-callback-url=http://localhost:5173/auth/google/callback
